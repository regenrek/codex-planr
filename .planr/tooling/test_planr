#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_DIR/test_planr.py" "$@"
fi

if command -v python >/dev/null 2>&1; then
  if python -c 'import sys; raise SystemExit(0 if sys.version_info[:1] >= (3,) else 1)' >/dev/null 2>&1; then
    exec python "$SCRIPT_DIR/test_planr.py" "$@"
  fi
  echo "error: \`python\` is available but is not Python 3" >&2
  exit 1
fi

echo "error: could not find \`python3\` or \`python\` (Python 3) in PATH" >&2
exit 127
